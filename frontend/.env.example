# TNC Guardian - Frontend Environment Variables Example
# Copy this file to '.env' inside the frontend directory for local development.

# Target Backend REST API Gateway URL
VITE_API_URL=http://localhost:8000/api

# Frontend Application Display Name
VITE_APP_NAME=TNC Guardian

# Frontend Environment Name (development / production)
VITE_ENV=development

# Feature Flag: Enable Demo Mode Toggles (true / false)
VITE_ENABLE_DEMO_MODE=true
