# TNC Guardian - Backend Environment Configuration Example
# Copy this file to '.env' inside the backend/ directory for local development.

# --- DATABASE CONFIGURATION ---
DATABASE_URL=postgresql+asyncpg://postgres:Nikhi%402004@localhost:5432/TNC-guardian

# --- SECURITY & AUTHENTICATION ---
JWT_SECRET=generate_a_secure_jwt_secret_in_production_key_here

# --- AI & LLM PROVIDERS ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- CLOUD STORAGE (AWS S3) ---
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
S3_BUCKET=tnc-guardian-uploads
