# TNC Guardian - Backend Environment Configuration Example
# Copy this file to '.env' inside the backend/ directory for local development.

# --- ENVIRONMENT & SERVING ---
# Environment mode (development / production)
APP_ENV=development
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Backend listening host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- DATABASE CONFIGURATION ---
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/TNC-guardian

# --- SECURITY & AUTHENTICATION ---
# Secret key used for JWT signing (Generate a secure random key in production)
JWT_SECRET=your_jwt_secret_key_placeholder_here
# JWT algorithm to use
JWT_ALGORITHM=HS256
# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- AI & LLM PROVIDERS ---
# Anthropic Claude API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-placeholder
# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-placeholder
# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-placeholder
# OpenAI model designation for analysis (e.g., gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Run the application in offline demo mode using mock service (true / false)
DEMO_MODE=true

# --- CLOUD STORAGE (AWS S3) ---
# AWS Access Key ID
AWS_ACCESS_KEY=your-aws-access-key-placeholder
# AWS Secret Access Key
AWS_SECRET_KEY=your-aws-secret-key-placeholder
# AWS S3 Bucket Name
S3_BUCKET=tnc-guardian-uploads

# --- CORS CONFIGURATION ---
# Comma-separated list of allowed origins or "*"
CORS_ORIGINS=*

# --- UPLOAD & STORAGE CONFIGURATION ---
# Free Plan upload limit in MB
FREE_PLAN_UPLOAD_LIMIT_MB=5
# Pro Plan upload limit in MB
PRO_PLAN_UPLOAD_LIMIT_MB=25

# --- OCR CONFIGURATION ---
# Use hardware acceleration (true / false)
OCR_USE_GPU=true
# Comma-separated list of target language codes
OCR_LANGUAGES=en

# --- RATE LIMIT CONFIGURATION ---
# Maximum analysis requests allowed in the window
RATE_LIMIT_LIMIT=15
# Time window size in seconds
RATE_LIMIT_WINDOW_SECONDS=60
