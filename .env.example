# ==============================================================================
# TNC Guardian - Global Environment Configuration Example
# Copy this file to '.env' and populate the values for local development.
# ==============================================================================

# --- ENVIRONMENT & SERVING ---
# Environment mode (development / production)
APP_ENV=development
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Backend listening host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- DATABASE CONFIGURATION ---
# PostgreSQL connection URL (e.g. postgresql+asyncpg://user:password@host:port/dbname)
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@db:5432/TNC-guardian

# --- SECURITY & AUTHENTICATION ---
# Secret key used for signing JWT tokens (Generate a strong random string in production)
JWT_SECRET=your_jwt_secret_key_placeholder_here
# JWT algorithm to use
JWT_ALGORITHM=HS256
# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- AI & LLM PROVIDERS ---
# Anthropic API Key (Claude 3.5 Sonnet analysis engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OpenAI API Key (Whisper transcription fallback / alternatives)
OPENAI_API_KEY=your_openai_api_key_here
# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI model designation for analysis (e.g., gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Run the application in offline demo mode using mock service (true / false)
DEMO_MODE=true

# --- CLOUD STORAGE (AWS S3) ---
# AWS Access Key ID for S3 bucket file storage
AWS_ACCESS_KEY=your_aws_access_key_here
# AWS Secret Access Key
AWS_SECRET_KEY=your_aws_secret_key_here
# Target AWS S3 Bucket Name
S3_BUCKET=tnc-guardian-uploads

# --- CORS CONFIGURATION ---
# Comma-separated list of allowed origins or '*' to allow all
CORS_ORIGINS=*

# --- UPLOAD & STORAGE CONFIGURATION ---
# Free Plan upload limit in MB
FREE_PLAN_UPLOAD_LIMIT_MB=5
# Pro Plan upload limit in MB
PRO_PLAN_UPLOAD_LIMIT_MB=25

# --- OCR CONFIGURATION ---
# Use hardware acceleration (true / false)
OCR_USE_GPU=true
# Comma-separated list of target language codes
OCR_LANGUAGES=en

# --- RATE LIMIT CONFIGURATION ---
# Maximum analysis requests allowed in the window
RATE_LIMIT_LIMIT=15
# Time window size in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ==============================================================================
# FRONTEND CONFIGURATIONS (Vite Client)
# ==============================================================================
# Local Vite client port configuration
VITE_PORT=3000
# Backend API server URL
VITE_API_URL=http://localhost:8000/api
# Frontend App Name
VITE_APP_NAME=TNC Guardian
# Frontend Environment (development / production)
VITE_ENV=development
# Enable frontend demo mode indicators (true / false)
VITE_ENABLE_DEMO_MODE=true
